
# 以下的内容都可以在.env.local里进行放置，它的优先级会更高，同时不会上传到github仓库

#支持多账户，使用逗号分隔每个账户，密码中有特殊字符可能会导致识别失败
USERNAMES=hunterkill@hunterkill.onmicrosoft.com
PASSWORDS=hunterkill@8 # 密码外面要加上双引号,密码内部如果有双引号,需要加上转义字符，linux使用\转义，Windows使用"转义 (注意GitHub action不需要增加处理,也不需要加引号)
COOKIES="-t=0AkpxE0ZN333pfUlR4ZM0FRecJqP%2B5LNSB7jlEEsNwc7iod1MUMU6cbgwffEj8hDWvz1Cq4rXq5qao5%2B8i1DUbYIVxydXwYdxA90rQ0E%2FATc32fzqcpB1JfbZzwP5Oe9l%2ByfBZo2ACKSfTuXwJyHLfLdGr33Q7AFRc040rbE2E4fJQicvTdqAKYnPrQn2AfMo172F6VPN%2F7fCoalMtxvRRwW72PU5G7%2BPLC1QAsRKg2Qu198C3kt1M98feLSWJTTOEOk%2BVd1c%2Fq7HKrjyvb6k9NeB5bVkJyWHc5Jw0xPRbw%3D--e4E1IsYh0QkVSSqV--4A1eMbPh1v3M7SfPcaGwTA%3D%3D" # 使用cookie登录，多个账户的cookie使用逗号分隔开,在网页中找到_t=开头的cookie，例如：COOKIES="_t=lnm123,_t=abc123,_t=def456"
WEBSITE=https://linux.do  # 需要阅读的网站，支持后面那些：https://meta.discourse.org, https://meta.appinn.net, https://community.openai.com
# 是否开启自动点赞
AUTO_LIKE=true
# 是否在日志中隐藏账号名（默认为true，即隐藏账号名；设置为false可显示完整账号名）
HIDE_ACCOUNT_INFO=true
#运行时间，单位为分钟
RUN_TIME_LIMIT_MINUTES=20
# 每批最多同时运行的账号数
MAX_CONCURRENT_ACCOUNTS=3
# 电报通知报错信息（可不填）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
